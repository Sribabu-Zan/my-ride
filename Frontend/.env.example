# Base URL of the backend API
VITE_BASE_URL=http://localhost:4000

# Optional: OSRM routing server used to draw route lines on the map.
# Defaults to the public demo server when unset (strict rate limits — use your
# own/self-hosted instance in production). Maps no longer require an API key.
VITE_OSRM_URL=https://router.project-osrm.org
