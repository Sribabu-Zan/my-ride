# Server
PORT=4000

# MongoDB connection string
DB_CONNECT=mongodb://localhost:27017/uber-clone

# Secret used to sign JWTs (use a long random value in production)
JWT_SECRET=change-me

# Maps providers (keyless OpenStreetMap services).
# Defaults are the public demo servers; override with your own/self-hosted
# instances for production (the public servers have strict rate limits).
# NOTE: MAPS_API_KEY is no longer used — maps now run on Nominatim + OSRM.
NOMINATIM_URL=https://nominatim.openstreetmap.org
OSRM_URL=https://router.project-osrm.org
NOMINATIM_USER_AGENT=uber-clone/1.0 (maps service)
# Comma-separated ISO country codes to bias geocoding (default: India).
GEOCODE_COUNTRY_CODES=in
